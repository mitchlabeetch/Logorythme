# AI Provider API Keys — configure at least one
# Hugging Face (RECOMMENDED — StarVector for dedicated SVG generation)
HF_API_KEY=your_huggingface_token

# Vercel AI Gateway — access 100+ models with one key
VERCEL_GATEWAY_KEY=your_vercel_ai_gateway_key

# Direct provider keys (optional — used as fallback)
GOOGLE_AI_API_KEY=your_google_key
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key

# Custom OpenAI-compatible provider (Groq, Together, Fireworks, Ollama, etc.)
CUSTOM_PROVIDER_KEY=your_custom_key
CUSTOM_PROVIDER_BASE_URL=https://api.groq.com/openai/v1
# Preset: groq, together, fireworks, perplexity, ollama (optional — auto-detects from URL)
CUSTOM_PROVIDER_PRESET=groq

# Server
PORT=3001
NODE_ENV=production
LOG_LEVEL=info

# Security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# AI Defaults — StarVector as primary, Gemini as fallback
DEFAULT_MODEL=huggingface/starvector-8b
FALLBACK_MODELS=vercel-gateway/google/gemini-2.0-flash,google/gemini-2.5-flash,openai/gpt-4o

# Image preprocessing — optimizes images before AI (saves tokens)
AI_MAX_IMAGE_DIMENSION=1024
AI_IMAGE_QUALITY=90
AI_TARGET_FILE_SIZE=5242880

# File handling
MAX_FILE_SIZE_MB=10
RETENTION_DAYS=30

# Sentry (optional)
SENTRY_DSN=
